        <!--
            To publish a new release:
            1. Archive the app in Xcode (Product > Archive)
            2. Export as .dmg or .zip
            3. Sign: ./sign_update <path-to-zip>
               (sign_update is in Sparkle's bin/ alongside generate_keys)
            4. Add a new <item> below with the edSignature and length from sign_update
            5. Upload the .zip/.dmg to GitHub Releases
            6. Commit the updated appcast.xml and push
        -->
    </channel>
</rss>
